public class Main {

    public static void main(String[] args) {
        System.out.print("sistema bancario");

        ContaBancaria conta;

        conta = new ContaBancaria();

        conta.agencia = 123;
        conta.numero= 123456;
        conta.cliente = "black penciliano";
        conta.saldo = 1000.50;

        
        
        System.out.println(conta.toString());
        System.out.println("depositando...");
        conta.depositar(300);
        System.out.println(conta.toString());
        System.out.println("sacando o black money sujo");
        conta.sacar(900);
        System.out.println(conta.toString());


}
}


