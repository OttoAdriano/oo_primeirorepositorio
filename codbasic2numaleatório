import java.util.Scanner;
import java.util.Random;

public class JogoAdivinhacao {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Random random = new Random();
        
        int numeroSecreto = random.nextInt(100) + 1;
        int tentativas = 0;
        int chute = 0;

        System.out.println("Bem vindo ao jogo de adivinhacao!");
        System.out.println("Tente adivinhar o numero entre 1 e 100.");
        System.out.println("\n\n\n");
        while (chute != numeroSecreto) {
            System.out.print("Digite seu chute: ");
            chute = scanner.nextInt();
            tentativas++;

            if (chute < numeroSecreto) {
                System.out.println("O numero secreto e maior que " + chute + ".");
            } else if (chute > numeroSecreto) {
                System.out.println("O numero secreto e menor que " + chute + ".");
            } else {
                System.out.println("Parabens! Voce acertou o numero " + numeroSecreto + ".");
                System.out.println("Voce precisou de " + tentativas + " tentativa(s).");
            }
        }
        
    }
}
